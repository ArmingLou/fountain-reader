{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fountain Reader",
  "version": "0.1.0",
  "identifier": "com.fountain.reader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Fountain Reader",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "cli": {
      "description": "Fountain Reader - A standalone Fountain screenplay reader",
      "args": [
        {
          "name": "source",
          "index": 1,
          "takesValue": true,
          "multiple": false,
          "description": "Fountain source file path"
        },
        {
          "name": "editor",
          "short": "e",
          "takesValue": true,
          "multiple": false,
          "description": "External editor to use (e.g., zed, code, subl)"
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
